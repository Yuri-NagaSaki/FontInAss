# Server settings
PORT=3000

# Security — set a strong random key (required for font management endpoints)
API_KEY=change-me-to-a-strong-secret

# Paths (relative to server/ directory or absolute)
FONT_DIR=./fonts
DB_PATH=./data/fonts.db

# CORS — set to your frontend origin in production
# Example: CORS_ORIGIN=http://localhost:5173
CORS_ORIGIN=*

# Subsetting concurrency (max fonts processed simultaneously per request)
SUBSET_CONCURRENCY=5

# In-memory result cache (number of processed subtitle results to keep in RAM)
CACHE_MAX_ENTRIES=500

# Log level: error | warn | info | debug
LOG_LEVEL=info
