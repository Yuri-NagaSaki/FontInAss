# FontInAss Local — Docker environment variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# Authentication key for font management endpoints
# Leave empty for open access (not recommended for production)
API_KEY=change-me-to-a-strong-secret

# CORS origin (set to your domain in production)
CORS_ORIGIN=*

# Subsetting concurrency
SUBSET_CONCURRENCY=5

# Log level
LOG_LEVEL=info
