# FontInAss Local — Docker environment variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# Authentication key for font management endpoints
# Leave empty for open access (not recommended for production)
API_KEY=change-me-to-a-strong-secret

# CORS origin (set to your domain in production)
CORS_ORIGIN=*

# Subsetting concurrency
SUBSET_CONCURRENCY=5

# Log level
LOG_LEVEL=info

# ─── R2 Sharing (optional — required for subtitle sharing feature) ─────────
# Cloudflare R2 credentials for subtitle archive storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Sharing settings
SHARING_MAX_FILE_SIZE=209715200
SHARING_RATE_LIMIT=3
SHARING_CACHE_TTL=300
